# =============================================================================
# SLACK CLONE – Environment variables reference
# =============================================================================
# Copy this to .env.local and fill in values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Convex (backend / realtime DB)
# -----------------------------------------------------------------------------
# From Convex Dashboard after: pnpm convex:dev  or  npx convex dashboard
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# -----------------------------------------------------------------------------
# App URL
# -----------------------------------------------------------------------------
# Used in invite emails (sign-up link). Set to your production URL when deployed.
APP_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# SMTP (sending invite emails)
# -----------------------------------------------------------------------------
# Convex uses these to send workspace/channel invite emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=Slack Clone

# -----------------------------------------------------------------------------
# Stack Auth (ManjuAuth) – sign-in / sign-up
# -----------------------------------------------------------------------------
# From your ManjuAuth/Stack project dashboard.
# Used by the app to validate email+password and get a user id; Convex then
# creates/updates the user and the app uses Convex userId everywhere.
NEXT_PUBLIC_STACK_API_URL=https://api.manjuauth.aivida.in
NEXT_PUBLIC_STACK_PROJECT_ID=your-project-id
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=pck_xxxx
STACK_SECRET_SERVER_KEY=ssk_xxxx

# -----------------------------------------------------------------------------
# Web Push (browser notifications when someone messages you)
# -----------------------------------------------------------------------------
# Generate once: npx web-push generate-vapid-keys
# Public key: in .env.local (client). Same public + private: in Convex Dashboard
#   → Settings → Environment Variables: VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key
# VAPID_PRIVATE_KEY=your-private-key   ← only in Convex Dashboard, NOT in .env.local
